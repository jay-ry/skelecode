# Phase 3: Auth + Database
# Copy to .env.local and fill with your own values.

# Neon Postgres connection string
# Source: https://console.neon.tech -> Project -> Connection Details
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Clerk API keys
# Source: https://dashboard.clerk.com -> Your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Custom sign-in/up URLs (REQUIRED — without these, Clerk redirects to accounts.clerk.dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Backend (existing, unchanged)
BACKEND_URL=http://localhost:8000
